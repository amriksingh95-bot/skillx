DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skillxt?schema=public"
JWT_SECRET=your_64_char_random_hex_string_here
JWT_REFRESH_SECRET=skillxt_rewards_super_secret_refresh_jwt_key_2026
PORT=5000
API_URL=http://127.0.0.1:5000
FRONTEND_URL=https://your-deployed-frontend-url.com
NODE_ENV=development

# Gmail SMTP Integration Settings
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# WhatsApp Alerts (CallMeBot)
ADMIN_WHATSAPP_NUMBER=91XXXXXXXXXX
ADMIN_WHATSAPP_APIKEY=XXXXXXXX

# Scheduler verbose logging (set to 'true' to enable detailed scheduler logs)
SCHEDULER_VERBOSE_LOGS=false

# Supabase Storage (for file uploads — payment screenshots, ad screenshots, etc.)
# SUPABASE_URL: Your Supabase project URL (e.g. https://xxxxx.supabase.co)
#   -> Extract from your DATABASE_URL: the project ref is "db.brbtufglemmhswioajxb"
#   -> So your SUPABASE_URL = https://brbtufglemmhswioajxb.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_KEY: The "service_role" key from Supabase dashboard > Settings > API
#   -> This bypasses RLS — never expose this in frontend code
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# SUPABASE_BUCKET: The storage bucket name to upload files into
#   -> Create this bucket in Supabase dashboard > Storage > New Bucket
#   -> Expected folders inside: payment-screenshots/, topup-screenshots/, ad-payment-screenshots/
SUPABASE_BUCKET=uploads
