generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String?        @unique
  mobile        String         @unique
  password      String
  role          String         @default("customer")
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  complaints    Complaint[]
  customer      Customer?
  merchant      Merchant?
  refreshTokens RefreshToken[]
}

model Merchant {
  id              String          @id @default(uuid())
  userId          String          @unique
  businessName    String
  ownerName       String
  email           String?
  address         String?
  city            String?
  category        String
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  closingTime     String?
  googleMapsUrl   String?
  isOpen          Boolean         @default(true)
  landmark        String?
  latitude        Float?
  longitude       Float?
  openingTime     String?
  pointsBalance   Int             @default(0)
  workingDays     String?
  status          MerchantStatus  @default(pending)
  statusChangedAt DateTime?
  statusChangedBy String?
  paymentScreenshot String?
  alternativePhone  String?
  merchantCode      String?       @unique
  advertisements  Advertisement[]
  auditLogs       AuditLog[]
  user            User            @relation(fields: [userId], references: [id])
  transactions    Transaction[]
  subscriptions   MerchantSubscription[]
  topUps           PointsTopUp[]
}

model Customer {
  id                   String         @id @default(uuid())
  userId               String         @unique
  name                 String
  email                String?
  qrCode               String         @unique
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  anniversaryDate      DateTime?
  area                 String?
  city                 String?
  communicationPref    String?        @default("email")
  dateOfBirth          DateTime?
  dietaryPreference    String?
  favouriteCategories  String?
  gender               String?
  maritalStatus        String?
  notificationOptIn    Boolean        @default(true)
  numberOfChildren     Int?           @default(0)
  occupation           String?
  pinCode              String?
  preferredLanguage    String?        @default("English")
  profilePhoto         String?
  referralCode         String?        @unique
  referredBy           String?
  signedUpViaMerchantId String?
  updatedAt            DateTime       @updatedAt
  referralPointsEarned Int            @default(0)
  alternativePhone      String?
  user                 User           @relation(fields: [userId], references: [id])
  ledgerEntries        PointsLedger[]
  transactions         Transaction[]
}

model Transaction {
  id             String            @id @default(uuid())
  customerId     String
  merchantId     String
  type           TransactionType
  invoiceAmount  Decimal? @db.Decimal(10, 2)
  purchaseAmount Decimal?
  platformFee    Decimal?
  netAmount      Decimal?
  points         Int
  remarks        String?
  status         TransactionStatus @default(completed)
  reversedById   String?
  reversedAt     DateTime?
  createdAt      DateTime          @default(now())
  ledgerEntries  PointsLedger[]
  customer       Customer          @relation(fields: [customerId], references: [id])
  merchant       Merchant          @relation(fields: [merchantId], references: [id])

  @@index([customerId])
  @@index([merchantId])
  @@index([createdAt])
  @@index([status])
  @@index([type])
}

model PointsLedger {
  id            String      @id @default(uuid())
  customerId    String
  transactionId String
  pointsChange  Int
  balanceAfter  Int
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())
  customer      Customer    @relation(fields: [customerId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([customerId])
  @@index([transactionId])
  @@index([createdAt])
}

model RewardSettings {
  id                  String   @id @default(uuid())
  pointsPerRupee      Decimal  @db.Decimal(10, 4)
  rupeesPerPoint      Decimal  @db.Decimal(10, 4)
  minRedeemPoints     Int      @default(100)
  pointsExpiryDays    Int      @default(365)
  redemptionFeePercent Decimal @default(5.00)
  updatedAt           DateTime @updatedAt
  updatedBy           String?
}

model AuditLog {
  id         String    @id @default(uuid())
  userId     String?
  merchantId String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  merchant   Merchant? @relation(fields: [merchantId], references: [id])
  user       User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([merchantId])
  @@index([createdAt])
  @@index([action])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model OTPVerification {
  id        String   @id @default(uuid())
  mobile    String
  otp       String
  purpose   String   @default("register")
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([mobile, purpose])
  @@index([expiresAt])
  @@index([mobile])
}

model OTPAttempt {
  id           String    @id @default(uuid())
  mobile       String
  purpose      String    @default("register")
  attemptCount Int       @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([mobile, purpose])
  @@map("otp_attempts")
}

model Complaint {
  id          String   @id @default(uuid())
  userId      String
  userRole    String
  userName    String
  type        String
  description String
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userRole])
  @@index([status])
  @@index([createdAt])
}

model Advertisement {
  id               String        @id @default(uuid())
  merchantId       String
  title            String
  description      String?
  imageUrl         String?
  ctaText          String        @default("Learn More")
  ctaLink          String?
  package          String
  status           String        @default("pending") // pending, approved, rejected, expired, live, paused, queued
  pausedReason     String?
  queuedAfterAdId  String?
  approvedAt       DateTime?
  startDate        DateTime?
  endDate          DateTime?
  impressions      Int           @default(0)
  clicks           Int           @default(0)
  showDirections   Boolean       @default(true)
  bg               String?
  accent           String?
  icon             String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  merchant         Merchant      @relation(fields: [merchantId], references: [id])
  payments         AdPayment[]

  @@index([merchantId])
  @@index([status])
}

model AdPayment {
  id              String    @id @default(uuid())
  advertisementId String
  amountPaid      Float
  screenshotPath  String?
  status          String    @default("pending") // pending, confirmed, rejected
  paidAt          DateTime?
  confirmedBy     String?
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id])
}

model MilestoneBonus {
  id          String   @id @default(uuid())
  spendTarget Decimal
  bonusPoints Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

enum TransactionType {
  earn
  redeem
  transfer
  reversal
  adjustment
}

enum TransactionStatus {
  completed
  pending
  failed
  reversed
}

enum MerchantStatus {
  pending
  approved
  payment_pending
  active
  suspended
  deactivated
  rejected
}

enum SubscriptionStatus {
  active
  grace_period
  expired
  cancelled
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique
  displayName   String
  price         Decimal  @db.Decimal(10, 2)
  durationDays  Int
  features      Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  merchantSubscriptions MerchantSubscription[]
}

model MerchantSubscription {
  id              String            @id @default(uuid())
  merchantId      String
  planId          String
  startDate       DateTime
  endDate         DateTime
  status          SubscriptionStatus @default(active)
  gracePeriodEnd  DateTime?
  autoRenew       Boolean           @default(false)
  paymentRef      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  merchant        Merchant          @relation(fields: [merchantId], references: [id])
  plan            SubscriptionPlan  @relation(fields: [planId], references: [id])

  @@index([merchantId])
  @@index([status])
  @@index([endDate])
}

model ChatLog {
  id        String   @id @default(uuid())
  message   String
  response  String
  userRole  String   @default("guest")
  userId    String?
  matched   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userRole])
  @@index([createdAt])
  @@index([matched])
}

enum TopUpStatus {
  pending
  confirmed
  rejected
}

model PointsTopUp {
  id               String       @id @default(uuid())
  merchantId       String
  packageName      String
  amountPaid       Float
  pointsToCredit   Int
  screenshotPath   String?
  status           TopUpStatus  @default(pending)
  confirmedBy      String?
  confirmedAt      DateTime?
  createdAt        DateTime     @default(now())
  merchant         Merchant     @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
}
