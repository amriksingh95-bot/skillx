DATABASE_URL=postgresql://user:password@host:6543/postgres
DIRECT_URL=postgresql://user:password@host:5432/postgres
JWT_SECRET=your-minimum-32-character-random-secret-here
JWT_REFRESH_SECRET=your-minimum-32-character-random-refresh-secret
PORT=5000
API_URL=https://api.skillxt.in
BACKEND_URL=https://api.skillxt.in
FRONTEND_URL=https://skillxt.in
NODE_ENV=production

# Gmail SMTP Integration Settings
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# WhatsApp Alerts (CallMeBot)
ADMIN_WHATSAPP_NUMBER=91XXXXXXXXXX
ADMIN_WHATSAPP_APIKEY=your_callmebot_api_key_here

# Telegram Notifications
TELEGRAM_USER_ID=your_telegram_user_id
TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# Gemini API (Chatbot)
GEMINI_API_KEY=your_gemini_api_key_here

# UPI Payment
UPI_ID=your_upi_id@provider

# Fast2SMS (SMS/OTP gateway)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Scheduler verbose logging (set to 'true' to enable detailed scheduler logs)
SCHEDULER_VERBOSE_LOGS=false

# Supabase Storage (for file uploads — payment screenshots, ad screenshots, etc.)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET=uploads
